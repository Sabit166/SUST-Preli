# ---------------------------------------------------------------------------
# LLM provider. Set to "groq" or "xai" (Grok).
# Leave AGENT_ENABLED=false if you want to run the server in pure keyword
# mode (no API key, no network, fully offline — what the judging fixture
# expects).
# ---------------------------------------------------------------------------
AGENT_ENABLED=true
LLM_PROVIDER=groq
LLM_TIMEOUT_SEC=8

# ---------------------------------------------------------------------------
# Groq (default)
# Get a key at https://console.groq.com/keys
# ---------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
model_name=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# xAI Grok (alternative). Only needed if LLM_PROVIDER=xai.
# Get a key at https://console.x.ai/
# ---------------------------------------------------------------------------
# XAI_API_KEY=your_xai_api_key_here
# model_name=grok-2
# XAI_BASE_URL=https://api.x.ai/v1