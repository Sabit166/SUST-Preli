        "user_type": "customer",
        "campaign_context": "boishakh_bonanza_day_1",
        "transaction_history": [
          {
            "transaction_id": "TXN-1001",
            "timestamp": "2026-04-14T10:15:00Z",
            "type": "transfer",
            "amount": 3000,
            "counterparty": "+8801799999999",
            "status": "completed"
          },
          {
            "transaction_id": "TXN-1002",
            "timestamp": "2026-04-14T09:00:00Z",
